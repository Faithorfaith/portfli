# Postgres connection string. Works with Vercel Postgres, Neon, Supabase, or any
# standard Postgres provider. Use the pooled/"transaction mode" connection string
# if your provider distinguishes one (Neon, Supabase) — Vercel's serverless
# functions open a fresh connection per invocation, so pooling matters.
DATABASE_URL="postgresql://user:password@host:5432/database"
