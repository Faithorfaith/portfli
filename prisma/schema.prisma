// OpenShelf Digital Library data model

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  READER
  ADMIN
}

enum OwnershipType {
  WROTE
  PERMISSION
  PUBLIC_DOMAIN
  FREE_LICENSED
}

enum BookStatus {
  DRAFT
  UNDER_REVIEW
  NEEDS_CHANGES
  APPROVED
  REJECTED
  REMOVED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  bio           String?
  isVerified    Boolean  @default(false)
  role          Role     @default(READER)
  points        Int      @default(0)
  walletBalance Int      @default(5000)
  earnings      Int      @default(0)
  createdAt     DateTime @default(now())

  books            Book[]           @relation("SubmittedBy")
  guestbookEntries GuestbookEntry[]
  tipsSent         Tip[]            @relation("TipsSent")
  tipsReceived     Tip[]            @relation("TipsReceived")
  savedBooks       SavedBook[]
  rewardLogs       RewardLog[]
  reports          Report[]
}

model Shelf {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  order       Int    @default(0)
  books       Book[]
}

model Book {
  id            String        @id @default(cuid())
  title         String
  authorName    String
  description   String
  language      String        @default("English")
  coverUrl      String?
  fileUrl       String?
  fileType      String?
  ownershipType OwnershipType
  status        BookStatus    @default(DRAFT)
  tipEligible   Boolean       @default(false)
  reads         Int           @default(0)
  saveCount     Int           @default(0)
  reviewNote    String?
  milestoneAwarded Int        @default(0)

  shelfId String
  shelf   Shelf  @relation(fields: [shelfId], references: [id])

  submittedById String
  submittedBy   User   @relation("SubmittedBy", fields: [submittedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guestbookEntries GuestbookEntry[]
  tips             Tip[]
  savedBy          SavedBook[]
  reports          Report[]
}

model SavedBook {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}

model GuestbookEntry {
  id           String   @id @default(cuid())
  bookId       String
  userId       String
  note         String
  type         String   @default("note")
  helpfulCount Int      @default(0)
  reported     Boolean  @default(false)
  status       String   @default("visible")
  rewarded     Boolean  @default(false)
  createdAt    DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Tip {
  id         String   @id @default(cuid())
  bookId     String
  fromUserId String
  toUserId   String
  amount     Int
  createdAt  DateTime @default(now())

  book     Book @relation(fields: [bookId], references: [id])
  fromUser User @relation("TipsSent", fields: [fromUserId], references: [id])
  toUser   User @relation("TipsReceived", fields: [toUserId], references: [id])
}

model Report {
  id           String   @id @default(cuid())
  targetType   String
  targetId     String
  bookId       String?
  reason       String
  status       String   @default("open")
  reportedById String
  createdAt    DateTime @default(now())

  reportedBy User  @relation(fields: [reportedById], references: [id])
  book       Book? @relation(fields: [bookId], references: [id])
}

model RewardLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
